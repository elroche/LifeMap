{% extends 'base.html.twig' %}

{% block title %}Modifier mon mot de passe{% endblock %}

{% block body %}
<div class="container py-4">

    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-white border-bottom border-4 border-primary py-3">
                    <h4 class="mb-0 fw-semibold">
                        <i class="bi bi-shield-lock me-2"></i>
                        Modifier mon mot de passe
                    </h4>
                </div>

                <div class="card-body p-4">

                    {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

                        {{ form_errors(form) }}

                        <div class="mb-4">
                            {{ form_label(form.currentPassword, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                            {{ form_widget(form.currentPassword, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(form.currentPassword) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.plainPassword.first, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                            {{ form_widget(form.plainPassword.first, { attr: { class: 'form-control' } }) }}

                            {{ form_errors(form.plainPassword) }}
                            {{ form_errors(form.plainPassword.first) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.plainPassword.second, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                            {{ form_widget(form.plainPassword.second, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(form.plainPassword.second) }}
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">

                            <a href="{{ path('app_account') }}" class="btn btn-outline-secondary">
                                Annuler
                            </a>

                            <button type="submit" class="btn btn-primary">
                                Modifier le mot de passe
                            </button>

                        </div>

                    {{ form_end(form) }}

                </div>

            </div>

        </div>
    </div>

</div>
{% endblock %}