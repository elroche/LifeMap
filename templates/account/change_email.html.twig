{% extends 'base.html.twig' %}
{% block body %}
    <h1>Confirme ton changement d'email</h1>

    <p>
        Tu as demandé à modifier ton adresse email sur ton compte.
    </p>

    <p>
        Pour valider ce changement, clique sur le lien ci-dessous :
    </p>

    <p>
        {#<a href="{{ confirmUrl }}">#}
