<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}LifeMap{% endblock %}</title>
        {#<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">#}
        <link rel="stylesheet" href="{{ asset('css/app.css') }}">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        {#{% block stylesheets %}
        {% endblock %}#}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>

    {% set currentRoute = app.request.attributes.get('_route') %}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <body class="{{ app.user ? 'authenticated' : 'guest' }}">
        {% if app.user %}

            <nav class="sidebar">
                <a href="{{ path('app_home') }}"
                    class="{{ currentRoute == 'app_home' ? 'active' : '' }}">
                    {# TODO : BOUTON DEG #}
                    <i class="bi bi-house"></i>
                    Accueil
                </a>

                <a href="#"
                    {# A remplacer plus tard par le bon lien #}
                    {# href="{{ path('app_events') }}" #}
                    class="{{ currentRoute == 'app_events' ? 'active' : '' }}">
                    <i class="bi bi-calendar"></i>
                    Evénements
                </a>

                <a href="#"
                    {# A remplacer plus tard par le bon lien #}
                    {# href="{{ path('app_timeline') }}" #}
                    class="{{ currentRoute == 'app_timeline' ? 'active' : '' }}">
                    <i class="bi bi-clock"></i>
                    Chronologie
                </a>

                <a href="#"
                    {# A remplacer plus tard par le bon lien #}
                    {# href="{{ path('app_event_create') }}" #}
                    class="{{ currentRoute == 'app_event_create' ? 'active' : '' }}">
                    <i class="bi bi-plus-circle"></i>
                    Ajouter un événement
                </a>
                
                <a href="#"
                    {# A remplacer plus tard par le bon lien #}
                    {# href="{{ path('app_skills') }}" #}
                    class="{{ currentRoute == 'app_skills' ? 'active' : '' }}">
                    <i class="bi bi-trophy"></i>
                    Compétences et tags
                </a>
                
                <a href="#"
                    {# A remplacer plus tard par le bon lien #}
                    {# href="{{ path('app_stats') }}" #}
                    class="{{ currentRoute == 'app_stats' ? 'active' : '' }}">
                    <i class="bi bi-bar-chart-line"></i>
                    Analyses et statistiques
                </a>
                
                <a href="#"
                    {# A remplacer plus tard par le bon lien #}
                    {# href="{{ path('app_favorites') }}" #}s
                    class="{{ currentRoute == 'app_favorites' ? 'active' : '' }}">
                    <i class="bi bi-heart"></i>
                    Favoris
                </a>
            </nav>
        
        {% endif %}


        {% if app.user %}
            <div class="main-container">
                <header class="topbar">

                    <form class="search-form">
                        <div class="search-wrapper">
                            <i class="fa-solid fa-magnifying-glass search-icon"></i>

                            <input
                                type="text"
                                placeholder="Rechercher un événement..."
                                class="search-input">
                        </div>
                    </form>

                    <div class="dropdown h-100">
                        <button
                            class="btn btn-light border d-flex align-items-center gap-4 dropdown-toggle"
                            type="button"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                        >
                            <i class="bi bi-person-circle"></i>

                            <div class="user-info">
                                <div class="user-name">
                                    {{ app.user.username ?: app.user.firstname }}
                                </div>

                                {% if is_granted('ROLE_ADMIN') %}
                                    <div class="user-role">
                                        Admin
                                    </div>
                                {% endif %}
                            </div>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="#">
                                    <i class="bi bi-gear me-2"></i>
                                    Gestion du compte
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                    <i class="bi bi-box-arrow-right me-2"></i>
                                    Déconnexion
                                </a>
                            </li>
                        </ul>
                    </div>
                </header>
            </div>
        {% endif %}

        <main class="content">
            {% block body %}{% endblock %}
        </main>

    </body>
</html>
